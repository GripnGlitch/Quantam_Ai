rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuth() { return request.auth != null; }
    function userData() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function isAdmin() { return userData().role == 'admin'; }
    function isMod() { return userData().role == 'moderator'; }
    function isLeaderOf(cId) { return userData().role == 'leader' && userData().communityId == cId; }
    function isMemberOf(cId) { return userData().communityId == cId; }

    match /users/{userId} {
      allow read: if isAuth();
      allow write: if isAuth() && (request.auth.uid == userId || isAdmin());
    }
    match /globalMessages/{id} {
      allow read: if isAuth();
      allow create: if isAuth() && (isAdmin() || isMod() || !get(/databases/$(database)/documents/settings/globalMute).data.muted);
      allow delete: if isAdmin();
    }
    match /communities/{cId}/messages/{id} {
      allow read: if isAuth() && isMemberOf(cId);
      allow create: if isAuth() && isMemberOf(cId) && (isAdmin() || isMod() || isLeaderOf(cId) || !get(/databases/$(database)/documents/communities/$(cId)).data.muted);
      allow delete: if isAdmin() || isMod() || isLeaderOf(cId);
    }
    match /privateChats/{chatId} {
      allow read: if isAuth() && (isAdmin() || resource.data.participants.hasAny([request.auth.uid]));
      allow write: if isAuth() && (isAdmin() || resource.data.participants.hasAny([request.auth.uid]));
    }
    match /privateChats/{chatId}/messages/{msgId} {
      allow read: if isAuth() && (isAdmin() || get(/databases/$(database)/documents/privateChats/$(chatId)).data.participants.hasAny([request.auth.uid]));
      allow create: if isAuth() && get(/databases/$(database)/documents/privateChats/$(chatId)).data.participants.hasAny([request.auth.uid]);
      allow update: if isAuth() && (isAdmin() || request.auth.uid == resource.data.senderId);
      allow delete: if isAdmin();
    }
    match /announcements/{id} {
      allow read: if isAuth();
      allow create: if isAuth() && (isAdmin() || isMod());
      allow delete: if isAdmin();
    }
    match /events/{id} {
      allow read: if isAuth();
      allow create: if isAuth() && (isAdmin() || isMod() || isLeaderOf(resource.data.communityId));
      allow delete: if isAdmin() || isMod() || isLeaderOf(resource.data.communityId);
    }
    match /pendingEvents/{id} { allow read, write: if isAuth(); }
    match /polls/{id} { allow read: if isAuth(); allow create: if isAuth(); }
    match /files/{id} { allow read: if isAuth(); allow create: if isAuth(); allow delete: if isAdmin() || request.auth.uid == resource.data.uploaderId; }
    match /settings/{doc} { allow read: if isAuth(); allow write: if isAdmin(); }
    match /adminAuditLogs/{id} { allow read, write: if isAdmin(); }
  }
}
